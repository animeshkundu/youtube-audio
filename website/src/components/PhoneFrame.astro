---
import { url } from '../consts';
// A restrained phone silhouette for Android captures, so mobile UI is never
// framed in desktop window chrome.
interface Props {
  src: string;
  alt: string;
  glow?: 'coral' | 'teal' | 'none';
  class?: string;
}
const { src, alt, glow = 'teal', class: cls = '' } = Astro.props;
---

<figure class:list={['phone', `phone--glow-${glow}`, cls]}>
  <div class="phone__notch" aria-hidden="true"></div>
  <div class="phone__screen">
    <img src={url(src)} alt={alt} loading="lazy" decoding="async" />
  </div>
</figure>

<style>
  .phone {
    position: relative;
    margin: 0;
    width: 100%;
    max-width: 300px;
    aspect-ratio: 300 / 620;
    padding: 10px;
    border-radius: 42px;
    background: linear-gradient(160deg, #2a241f, #14100d);
    border: 1px solid var(--line-strong);
    box-shadow:
      var(--shadow-float),
      inset 0 0 0 2px rgba(0, 0, 0, 0.5);
    isolation: isolate;
  }
  .phone::after {
    content: '';
    position: absolute;
    inset: -12% -18% -18%;
    z-index: -1;
    border-radius: 60px;
    filter: blur(52px);
    opacity: 0.7;
  }
  .phone--glow-coral::after {
    background: radial-gradient(55% 55% at 50% 32%, var(--coral-glow), transparent 72%);
  }
  .phone--glow-teal::after {
    background: radial-gradient(55% 55% at 50% 32%, var(--teal-glow), transparent 72%);
  }
  .phone--glow-none::after {
    display: none;
  }
  .phone__notch {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 7px;
    border-radius: var(--r-pill);
    background: rgba(0, 0, 0, 0.55);
    z-index: 2;
  }
  .phone__screen {
    height: 100%;
    border-radius: 33px;
    overflow: hidden;
    background: #f4f2ef;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.15);
  }
  .phone__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
</style>
